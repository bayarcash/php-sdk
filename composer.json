{
    "name": "bayarcash/php-sdk",
    "description": "Bayarcash payment gateway PHP Sdk.",
    "type": "sdk",
    "require": {
        "guzzlehttp/guzzle": "^7.0",
        "php": "^7.4|^8.0",
        "ext-json": "*"
    },
    "require-dev": {
        "illuminate/support": "^7.0|^8.0|^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^9.5|^10.5"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Bayarcash\\BayarcashSdkServiceProvider"
            ],
            "alias": {
                "BayarcashSdk": "Bayarcash\\Facades\\Bayarcash"
            }
        }
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Bayarcash\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Bayarcash\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "authors": [
        {
            "name": "faiz",
            "email": "faizafzal@webmpian.com"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true
}
